<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Commesse</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
</head>
<body>
    <div class="container">
        <div class="row m-5">
            <div class="d-flex justify-content-between align-center mb-2">
                <h2><%= codice %></h2>
                <a href="/" class="btn btn-outline-primary">Torna alla lista</a>
            </div>

            <div class="row">
                <ul class="list-group col-6">
                    <% for(const p of produzione) { %>
                        <li class="list-group-item">pezzi prodotti: <%= p.pezzi_prodotti %></li>
                    <% } %>
                </ul>
                <div class="col-6">
                    ciao
                </div>
            </div>

        </div>
    </div>
</body>
</html>